# Django Core
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgis://rideshare:localpassword@db:5432/rideshare

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNEL_LAYERS_REDIS_URL=redis://redis:6379/1

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_PROXY_SERVICE_SID=your_proxy_service_sid

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_id

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=hyryder-documents
AWS_S3_REGION_NAME=ap-southeast-2
AWS_CLOUDFRONT_DOMAIN=

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Email (AWS SES)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
AWS_SES_REGION_NAME=ap-southeast-2

# OneSignal (Push Notifications)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_api_key

# Sentry
SENTRY_DSN=

# Encryption Key (for PII column encryption)
FIELD_ENCRYPTION_KEY=your-field-encryption-key-32-chars

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
